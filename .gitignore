# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
# Note: artifacts/api-server/dist/ is intentionally NOT ignored — it is committed
# so the production GCE deployment uses the pre-built bundle directly.
/dist
artifacts/dashboard/dist/
artifacts/mockup-sandbox/dist/
lib/*/dist/
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# Conversation assets (screenshots, pasted text - not part of source code)
attached_assets/

# Auto-generated JWT secret (fallback when JWT_SECRET env var is not set)
.jwt_secret
